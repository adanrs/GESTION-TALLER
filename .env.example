# Copiar a .env y completar. NO subir .env al repositorio.

# Puerto de la app
PORT=9900

# URL publica (para armar el enlace de recuperacion en el correo)
APP_URL=http://localhost:9900

# Secreto de sesion (cambiar en produccion)
SESSION_SECRET=cambia-esto-por-algo-aleatorio

# --- Correo SMTP (recuperacion de contrasena) ---
# Si se dejan vacios, el sistema NO envia correo: imprime el enlace en el log (modo dev).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu-contrasena-de-aplicacion
SMTP_FROM=Gestion Taller <tucorreo@gmail.com>

# Email inicial del admin (solo se usa al crear la BD por primera vez)
ADMIN_EMAIL=tucorreo@gmail.com
