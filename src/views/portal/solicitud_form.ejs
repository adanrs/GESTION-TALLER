<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0"><i class="bi bi-plus-circle"></i> Solicitar servicio</h2>
  <a href="/portal/solicitudes" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<% if (typeof errors !== 'undefined' && errors && errors.length) { %>
<div class="alert alert-danger" role="alert">
  <div class="fw-semibold mb-1"><i class="bi bi-exclamation-triangle"></i> Revisa los siguientes datos:</div>
  <ul class="mb-0">
    <% errors.forEach(function(e) { %>
    <li><%= typeof e === 'string' ? e : (e.msg || e.message || '') %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<div class="card">
  <div class="card-body">
    <% if (vehiculos && vehiculos.length) { %>
    <form method="POST" action="/portal/solicitudes">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="mb-3">
        <label class="form-label" for="vehiculo_id">Vehiculo</label>
        <select class="form-select" id="vehiculo_id" name="vehiculo_id" required>
          <option value="">Selecciona un vehiculo...</option>
          <% vehiculos.forEach(function(v) { %>
          <option value="<%= v.id %>"><%= v.placa %> - <%= v.marca %> <%= v.modelo %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label" for="descripcion">Descripcion</label>
        <textarea class="form-control" id="descripcion" name="descripcion" rows="5" required
                  placeholder="Describe que necesita tu vehiculo..."></textarea>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Enviar solicitud</button>
        <a href="/portal/solicitudes" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
    <% } else { %>
      <div class="text-center text-muted p-4">
        <i class="bi bi-car-front fs-1 d-block mb-2"></i>
        <p class="mb-0">No tienes vehiculos registrados.</p>
        <p class="small mb-0">Contacta al taller para registrar tu vehiculo antes de solicitar un servicio.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
