<%- include('../partials/header') %>

<h2><i class="bi bi-car-front"></i> <%= title %></h2>
<hr>

<% if (errors.length) { %>
<div class="alert alert-danger">
  <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<form method="POST" action="/vehiculos<%= vehiculo.id ? `/${vehiculo.id}/editar` : '/crear' %>">
  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Propietario *</label>
      <select name="cliente_id" class="form-select" required>
        <option value="">-- Seleccionar cliente --</option>
        <% clientes.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(vehiculo.cliente_id) === String(c.id) ? 'selected' : '' %>><%= c.nombre %> <% if(c.cedula) { %>(<%= c.cedula %>)<% } %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-6">
      <label class="form-label">Placa *</label>
      <input type="text" name="placa" class="form-control text-uppercase" value="<%= vehiculo.placa || '' %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Marca *</label>
      <input type="text" name="marca" class="form-control" value="<%= vehiculo.marca || '' %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Modelo *</label>
      <input type="text" name="modelo" class="form-control" value="<%= vehiculo.modelo || '' %>" required>
    </div>
    <div class="col-md-2">
      <label class="form-label">Ano</label>
      <input type="number" name="ano" class="form-control" value="<%= vehiculo.ano || '' %>" min="1900" max="2099">
    </div>
    <div class="col-md-2">
      <label class="form-label">Color</label>
      <input type="text" name="color" class="form-control" value="<%= vehiculo.color || '' %>">
    </div>
    <div class="col-md-6">
      <label class="form-label">VIN / Serial</label>
      <input type="text" name="vin" class="form-control" value="<%= vehiculo.vin || '' %>">
    </div>
    <div class="col-md-6">
      <label class="form-label">Notas</label>
      <input type="text" name="notas" class="form-control" value="<%= vehiculo.notas || '' %>">
    </div>
  </div>
  <div class="mt-4">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
    <a href="/vehiculos" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>

<%- include('../partials/footer') %>
