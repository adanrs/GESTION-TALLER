<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-car-front"></i> Vehiculos</h2>
  <a href="/vehiculos/crear" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Vehiculo</a>
</div>

<form class="row g-2 mb-3" method="GET">
  <div class="col-auto flex-grow-1">
    <input type="text" name="buscar" class="form-control" placeholder="Buscar por placa, marca, modelo o cliente..." value="<%= buscar %>">
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-secondary"><i class="bi bi-search"></i> Buscar</button>
  </div>
  <% if (buscar) { %>
  <div class="col-auto"><a href="/vehiculos" class="btn btn-outline-danger">Limpiar</a></div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (vehiculos.length) { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Placa</th>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Ano</th>
            <th>Color</th>
            <th>Propietario</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% vehiculos.forEach(v => { %>
          <tr>
            <td><a href="/vehiculos/<%= v.id %>"><strong><%= v.placa %></strong></a></td>
            <td><%= v.marca %></td>
            <td><%= v.modelo %></td>
            <td><%= v.ano || '-' %></td>
            <td><%= v.color || '-' %></td>
            <td><a href="/clientes/<%= v.cliente_id %>"><%= v.cliente_nombre %></a></td>
            <td class="text-end">
              <a href="/vehiculos/<%= v.id %>/editar" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/vehiculos/<%= v.id %>/eliminar" class="d-inline" onsubmit="return confirm('Eliminar este vehiculo y todo su historial?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="text-muted p-3 mb-0">No se encontraron vehiculos.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
