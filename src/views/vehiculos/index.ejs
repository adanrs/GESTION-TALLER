<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-car-front"></i> Vehiculos
    <% if (archivados) { %><span class="badge bg-secondary align-middle">Archivados</span><% } %>
  </h2>
  <div class="d-flex flex-wrap gap-2">
    <% if (archivados) { %>
      <a href="/vehiculos" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Ver activos</a>
    <% } else { %>
      <a href="/vehiculos?archivados=1" class="btn btn-outline-secondary"><i class="bi bi-archive"></i> Ver archivados</a>
      <a href="/vehiculos/crear" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Vehiculo</a>
    <% } %>
  </div>
</div>

<form class="row g-2 mb-3" method="GET">
  <% if (archivados) { %><input type="hidden" name="archivados" value="1"><% } %>
  <div class="col-12 col-md flex-md-grow-1">
    <input type="text" name="buscar" class="form-control" placeholder="Buscar por placa, marca, modelo o cliente..." value="<%= buscar %>">
  </div>
  <div class="col-6 col-md-auto">
    <button class="btn btn-outline-secondary w-100"><i class="bi bi-search"></i> Buscar</button>
  </div>
  <% if (buscar) { %>
  <div class="col-6 col-md-auto">
    <a href="<%= archivados ? '/vehiculos?archivados=1' : '/vehiculos' %>" class="btn btn-outline-danger w-100">Limpiar</a>
  </div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (vehiculos.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Placa</th>
            <th>Marca</th>
            <th class="d-none d-sm-table-cell">Modelo</th>
            <th class="d-none d-md-table-cell">Ano</th>
            <th class="d-none d-lg-table-cell">Color</th>
            <th class="d-none d-md-table-cell">Propietario</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% vehiculos.forEach(v => { %>
          <tr>
            <td>
              <a href="/vehiculos/<%= v.id %>" class="fw-semibold"><%= v.placa %></a>
              <div class="d-sm-none small text-muted"><%= v.marca %> <%= v.modelo %></div>
            </td>
            <td><%= v.marca %></td>
            <td class="d-none d-sm-table-cell"><%= v.modelo %></td>
            <td class="d-none d-md-table-cell"><%= v.ano || '-' %></td>
            <td class="d-none d-lg-table-cell"><%= v.color || '-' %></td>
            <td class="d-none d-md-table-cell"><a href="/clientes/<%= v.cliente_id %>"><%= v.cliente_nombre %></a></td>
            <td class="text-end text-nowrap">
              <a href="/vehiculos/<%= v.id %>" class="btn btn-sm btn-outline-secondary" title="Ver detalle">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/vehiculos/<%= v.id %>/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              <% if (archivados) { %>
              <form method="POST" action="/vehiculos/<%= v.id %>/restaurar" class="d-inline" onsubmit="return confirm('Restaurar este registro?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-success" title="Restaurar"><i class="bi bi-arrow-counterclockwise"></i></button>
              </form>
              <% } else { %>
              <form method="POST" action="/vehiculos/<%= v.id %>/eliminar" class="d-inline" onsubmit="return confirm('Archivar este registro?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-danger" title="Archivar"><i class="bi bi-archive"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-car-front fs-1 d-block mb-2"></i>
        <% if (buscar) { %>
          <p class="mb-0">No hay vehiculos que coincidan con la busqueda.</p>
          <a href="<%= archivados ? '/vehiculos?archivados=1' : '/vehiculos' %>" class="btn btn-sm btn-outline-secondary mt-2">Limpiar busqueda</a>
        <% } else if (archivados) { %>
          <p class="mb-0">No hay vehiculos archivados.</p>
          <a href="/vehiculos" class="btn btn-sm btn-outline-secondary mt-2"><i class="bi bi-arrow-left"></i> Ver activos</a>
        <% } else { %>
          <p class="mb-0">Aun no hay vehiculos registrados.</p>
          <a href="/vehiculos/crear" class="btn btn-sm btn-primary mt-2">
            <i class="bi bi-plus-lg"></i> Crear el primero
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
