<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0"><i class="bi bi-receipt"></i> Cotizaciones</h2>
  <a href="/cotizaciones/crear" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nueva Cotizacion</a>
</div>

<form class="row g-2 mb-3" method="GET">
  <div class="col-12 col-md flex-md-grow-1">
    <input type="text" name="buscar" class="form-control" placeholder="Buscar por numero, placa o cliente..." value="<%= buscar %>">
  </div>
  <div class="col-8 col-md-auto">
    <select name="estado" class="form-select">
      <option value="">Todos los estados</option>
      <% ['Borrador','Enviada','Aprobada','Rechazada','Pagada'].forEach(e => { %>
      <option value="<%= e %>" <%= estado === e ? 'selected' : '' %>><%= e %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-4 col-md-auto">
    <button class="btn btn-outline-secondary w-100"><i class="bi bi-search"></i> Filtrar</button>
  </div>
  <% if (buscar || estado) { %>
  <div class="col-12 col-md-auto"><a href="/cotizaciones" class="btn btn-outline-danger w-100">Limpiar</a></div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (cotizaciones.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Numero</th>
            <th class="d-none d-md-table-cell">Fecha</th>
            <th class="d-none d-md-table-cell">Vehiculo</th>
            <th class="d-none d-lg-table-cell">Cliente</th>
            <th class="text-end">Total</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% cotizaciones.forEach(c => { %>
          <tr>
            <td>
              <a href="/cotizaciones/<%= c.id %>"><strong><%= c.numero %></strong></a>
              <div class="d-md-none small text-muted"><%= c.placa %> <%= c.marca %> <%= c.modelo %></div>
            </td>
            <td class="d-none d-md-table-cell text-nowrap"><%= c.fecha ? c.fecha.substring(0, 10) : '' %></td>
            <td class="d-none d-md-table-cell"><%= c.placa %> <%= c.marca %> <%= c.modelo %></td>
            <td class="d-none d-lg-table-cell"><%= c.cliente_nombre %></td>
            <td class="text-end text-nowrap"><strong><%- simboloMoneda(c.moneda || 'USD') %><%= (c.total || 0).toFixed(2) %></strong></td>
            <td>
              <span class="badge bg-<%= badgeEstado(c.estado) %>"><%= c.estado %></span>
            </td>
            <td class="text-end text-nowrap">
              <a href="/cotizaciones/<%= c.id %>" class="btn btn-sm btn-outline-info" title="Ver" aria-label="Ver cotizacion"><i class="bi bi-eye"></i></a>
              <a href="/cotizaciones/<%= c.id %>/editar" class="btn btn-sm btn-outline-primary" title="Editar" aria-label="Editar cotizacion"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/cotizaciones/<%= c.id %>/eliminar" class="d-inline" onsubmit="return confirm('Eliminar esta cotizacion?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-danger" title="Eliminar" aria-label="Eliminar cotizacion"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-receipt fs-1 d-block mb-2"></i>
        <% if (buscar || estado) { %>
          <p class="mb-0">No hay cotizaciones que coincidan con el filtro.</p>
          <a href="/cotizaciones" class="btn btn-sm btn-outline-secondary mt-2">Limpiar filtros</a>
        <% } else { %>
          <p class="mb-0">Aun no hay cotizaciones registradas.</p>
          <a href="/cotizaciones/crear" class="btn btn-sm btn-primary mt-2">
            <i class="bi bi-plus-lg"></i> Crear la primera
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
