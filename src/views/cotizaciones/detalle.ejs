<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-receipt"></i> Cotizacion <%= cotizacion.numero %></h2>
  <div class="d-print-none d-flex flex-wrap gap-2">
    <a href="/cotizaciones/<%= cotizacion.id %>/pdf" target="_blank" class="btn btn-outline-dark"><i class="bi bi-file-earmark-pdf"></i> Ver PDF</a>
    <a href="/cotizaciones/<%= cotizacion.id %>/csv" class="btn btn-outline-success"><i class="bi bi-file-earmark-spreadsheet"></i> Exportar CSV</a>
    <% if (whatsapp) { %>
    <a href="https://wa.me/<%= whatsapp %>?text=Hola,%20le%20envio%20la%20cotizacion%20<%= cotizacion.numero %>" target="_blank" class="btn btn-success"><i class="bi bi-whatsapp"></i> WhatsApp</a>
    <% } %>
    <button onclick="window.print()" class="btn btn-outline-secondary"><i class="bi bi-printer"></i> Imprimir</button>
    <a href="/cotizaciones/<%= cotizacion.id %>/editar" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
    <a href="/cotizaciones" class="btn btn-outline-secondary">Volver</a>
  </div>
</div>

<div class="card d-print-none mb-3">
  <div class="card-body py-3">
    <h6 class="card-title text-muted mb-2"><i class="bi bi-lightning-charge"></i> Acciones</h6>
    <div class="d-flex flex-wrap gap-2">
      <% if (cotizacion.estado === 'Borrador') { %>
      <form method="POST" action="/cotizaciones/<%= cotizacion.id %>/estado" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="estado" value="Enviada">
        <button type="submit" class="btn btn-outline-info"><i class="bi bi-send"></i> Marcar enviada</button>
      </form>
      <% } %>
      <% if (cotizacion.estado === 'Borrador' || cotizacion.estado === 'Enviada') { %>
      <form method="POST" action="/cotizaciones/<%= cotizacion.id %>/estado" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="estado" value="Aprobada">
        <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Aprobar</button>
      </form>
      <% } %>
      <% if (cotizacion.estado === 'Borrador' || cotizacion.estado === 'Enviada' || cotizacion.estado === 'Aprobada') { %>
      <form method="POST" action="/cotizaciones/<%= cotizacion.id %>/estado" class="d-inline" onsubmit="return confirm('Rechazar esta cotizacion?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="estado" value="Rechazada">
        <button type="submit" class="btn btn-outline-danger"><i class="bi bi-x-lg"></i> Rechazar</button>
      </form>
      <% } %>
      <% if (cotizacion.estado === 'Enviada' || cotizacion.estado === 'Aprobada') { %>
      <form method="POST" action="/cotizaciones/<%= cotizacion.id %>/convertir" class="d-inline" onsubmit="return confirm('Crear una orden de servicio desde esta cotizacion?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary"><i class="bi bi-tools"></i> Convertir a orden</button>
      </form>
      <% } %>
      <% if (cotizacion.estado !== 'Pagada') { %>
      <form method="POST" action="/cotizaciones/<%= cotizacion.id %>/marcar-pagada" class="d-inline" onsubmit="return confirm('Marcar esta cotizacion como pagada?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-dark"><i class="bi bi-cash-coin"></i> Marcar pagada</button>
      </form>
      <% } %>
    </div>
  </div>
</div>

<form method="POST" action="/cotizaciones/<%= cotizacion.id %>/enviar-correo" class="d-print-none mb-4">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="input-group" style="max-width:480px">
    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
    <input type="email" name="email" class="form-control" value="<%= cotizacion.email || '' %>" placeholder="correo del cliente">
    <button type="submit" class="btn btn-primary"><i class="bi bi-envelope"></i> Enviar por correo</button>
  </div>
</form>

<div class="card mb-4">
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-md-6">
        <h5>Datos del Cliente</h5>
        <p class="mb-1"><strong><%= cotizacion.cliente_nombre %></strong></p>
        <% if (cotizacion.cedula) { %><p class="mb-1">Cedula/RIF: <%= cotizacion.cedula %></p><% } %>
        <% if (cotizacion.telefono) { %><p class="mb-1">Tel: <%= cotizacion.telefono %></p><% } %>
        <% if (cotizacion.email) { %><p class="mb-1"><%= cotizacion.email %></p><% } %>
      </div>
      <div class="col-md-6 text-md-end">
        <h5>Cotizacion</h5>
        <p class="mb-1"><strong>No:</strong> <%= cotizacion.numero %></p>
        <p class="mb-1"><strong>Fecha:</strong> <%= cotizacion.fecha ? cotizacion.fecha.substring(0, 10) : '' %></p>
        <p class="mb-1"><strong>Moneda:</strong> <%= (cotizacion.moneda || 'USD') === 'CRC' ? 'Colones (CRC)' : 'Dolares (USD)' %></p>
        <p class="mb-1"><strong>Estado:</strong>
          <span class="badge bg-<%= badgeEstado(cotizacion.estado) %>"><%= cotizacion.estado %></span>
        </p>
        <% if (cotizacion.estado === 'Pagada' && cotizacion.fecha_pago) { %>
        <p class="mb-1"><strong>Pagada:</strong> <%= cotizacion.fecha_pago %></p>
        <% } %>
      </div>
    </div>
    <hr>
    <div class="mb-3">
      <strong>Vehiculo:</strong> <%= cotizacion.placa %> - <%= cotizacion.marca %> <%= cotizacion.modelo %>
      <% if(cotizacion.ano) { %> (<%= cotizacion.ano %>)<% } %>
      <% if(cotizacion.color) { %> - <%= cotizacion.color %><% } %>
      <% if(cotizacion.vin) { %> | VIN: <%= cotizacion.vin %><% } %>
    </div>

    <div class="table-responsive">
      <table class="table">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Tipo</th>
            <th>Descripcion</th>
            <th class="text-center">Cantidad</th>
            <th class="text-end">Precio Unit.</th>
            <th class="text-end">Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% detalles.forEach((d, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><span class="badge bg-<%= d.tipo === 'Servicio' ? 'info' : 'warning' %>"><%= d.tipo %></span></td>
            <td><%= d.descripcion %></td>
            <td class="text-center"><%= d.cantidad %></td>
            <td class="text-end"><%- simbolo %><%= d.precio_unitario.toFixed(2) %></td>
            <td class="text-end"><%- simbolo %><%= (d.cantidad * d.precio_unitario).toFixed(2) %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="5" class="text-end"><strong>Subtotal:</strong></td>
            <td class="text-end"><strong><%- simbolo %><%= subtotal.toFixed(2) %></strong></td>
          </tr>
          <% if (cotizacion.aplica_iva) { %>
          <tr>
            <td colspan="5" class="text-end"><strong>IVA (<%= cotizacion.iva_porcentaje %>%):</strong></td>
            <td class="text-end"><strong><%- simbolo %><%= iva.toFixed(2) %></strong></td>
          </tr>
          <% } %>
          <tr class="table-dark">
            <td colspan="5" class="text-end"><strong>TOTAL:</strong></td>
            <td class="text-end fs-5"><strong><%- simbolo %><%= total.toFixed(2) %></strong></td>
          </tr>
          <% if (tc > 0) { %>
          <tr>
            <td colspan="5" class="text-end text-muted">Equivalente en <%= monedaAlterna %> (T.C. <%= tc %>):</td>
            <td class="text-end text-muted"><%- simboloAlt %><%= totalConvertido.toFixed(2) %></td>
          </tr>
          <% } %>
        </tfoot>
      </table>
    </div>

    <% if (cotizacion.garantia) { %>
    <div class="mt-3"><strong>Garantia:</strong> <%= cotizacion.garantia %></div>
    <% } %>

    <% if (cotizacion.notas) { %>
    <div class="mt-3"><strong>Notas:</strong> <%= cotizacion.notas %></div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
