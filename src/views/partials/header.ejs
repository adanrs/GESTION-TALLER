<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Gestion Taller</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/site.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-wrench-adjustable-circle"></i> Gestion Taller</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav ms-auto">
          <% if (typeof esCliente !== 'undefined' && esCliente) { %>
          <%# El cliente solo ve su portal %>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/portal' ? 'active' : '' %>" href="/portal"><i class="bi bi-house"></i> Inicio</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/portal' ? 'active' : '' %>" href="/portal#mis-vehiculos"><i class="bi bi-car-front"></i> Mis Vehiculos</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/portal/solicitudes/crear') ? 'active' : '' %>" href="/portal/solicitudes/crear"><i class="bi bi-plus-circle"></i> Solicitar servicio</a></li>
          <li class="nav-item"><a class="nav-link <%= (currentPath.startsWith('/portal/solicitudes') && !currentPath.startsWith('/portal/solicitudes/crear')) ? 'active' : '' %>" href="/portal/solicitudes"><i class="bi bi-inbox"></i> Mis Solicitudes</a></li>
          <% } else if (typeof esMecanico !== 'undefined' && esMecanico) { %>
          <%# El mecanico solo ve sus ordenes asignadas %>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/servicios') ? 'active' : '' %>" href="/servicios"><i class="bi bi-tools"></i> Mis Ordenes</a></li>
          <% } else { %>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/"><i class="bi bi-speedometer2"></i> Inicio</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/clientes') ? 'active' : '' %>" href="/clientes"><i class="bi bi-people"></i> Clientes</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/vehiculos') ? 'active' : '' %>" href="/vehiculos"><i class="bi bi-car-front"></i> Vehiculos</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/servicios') ? 'active' : '' %>" href="/servicios"><i class="bi bi-tools"></i> Servicios</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/cotizaciones') ? 'active' : '' %>" href="/cotizaciones"><i class="bi bi-receipt"></i> Cotizaciones</a></li>
          <% if (typeof esAdmin !== 'undefined' && esAdmin) { %>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/solicitudes') ? 'active' : '' %>" href="/solicitudes"><i class="bi bi-inbox"></i> Solicitudes</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/usuarios') ? 'active' : '' %>" href="/usuarios"><i class="bi bi-people-fill"></i> Usuarios</a></li>
          <% } %>
          <% } %>
        </ul>
        <% if (typeof usuario !== 'undefined' && usuario) { %>
        <ul class="navbar-nav ms-3">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i> <%= usuario.nombre %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><span class="dropdown-item-text text-muted small"><%= usuario.rol %></span></li>
              <li><hr class="dropdown-divider"></li>
              <% if (typeof esCliente !== 'undefined' && esCliente) { %>
              <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right"></i> Cerrar Sesion</a></li>
              <% } else { %>
              <li><a class="dropdown-item" href="/perfil"><i class="bi bi-person-gear"></i> Mi Perfil</a></li>
              <% if (typeof esAdmin !== 'undefined' && esAdmin) { %>
              <li><a class="dropdown-item" href="/accesos"><i class="bi bi-shield-lock"></i> Log de Accesos</a></li>
              <li><a class="dropdown-item" href="/configuracion"><i class="bi bi-gear"></i> Configuracion</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right"></i> Cerrar Sesion</a></li>
              <% } %>
            </ul>
          </li>
        </ul>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="container mt-4">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
