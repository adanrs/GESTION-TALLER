<%- include('partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h2 class="mb-1"><i class="bi bi-speedometer2"></i> Dashboard</h2>
    <p class="text-muted mb-0">Resumen general del taller</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-lg-3">
    <a href="/clientes" class="text-decoration-none">
      <div class="card stat-card stat-card--primary h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-card__icon"><i class="bi bi-people"></i></span>
          <div>
            <div class="stat-card__value"><%= totalClientes %></div>
            <div class="stat-card__label">Clientes</div>
          </div>
        </div>
      </div>
    </a>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <a href="/vehiculos" class="text-decoration-none">
      <div class="card stat-card stat-card--success h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-card__icon"><i class="bi bi-car-front"></i></span>
          <div>
            <div class="stat-card__value"><%= totalVehiculos %></div>
            <div class="stat-card__label">Vehiculos</div>
          </div>
        </div>
      </div>
    </a>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <a href="/servicios" class="text-decoration-none">
      <div class="card stat-card stat-card--warning h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-card__icon"><i class="bi bi-tools"></i></span>
          <div>
            <div class="stat-card__value"><%= serviciosActivos %></div>
            <div class="stat-card__label">Servicios Activos</div>
          </div>
        </div>
      </div>
    </a>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <a href="/cotizaciones" class="text-decoration-none">
      <div class="card stat-card stat-card--info h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-card__icon"><i class="bi bi-receipt"></i></span>
          <div>
            <div class="stat-card__value"><%= cotizacionesPendientes %></div>
            <div class="stat-card__label">Cotizaciones Pendientes</div>
          </div>
        </div>
      </div>
    </a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header"><h6 class="mb-0 text-uppercase text-muted"><i class="bi bi-lightning-charge"></i> Accesos rapidos</h6></div>
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <a href="/clientes/crear" class="btn btn-primary"><i class="bi bi-person-plus"></i> Nuevo Cliente</a>
      <a href="/cotizaciones/crear" class="btn btn-outline-primary"><i class="bi bi-file-earmark-plus"></i> Nueva Cotizacion</a>
      <a href="/servicios/crear" class="btn btn-outline-primary"><i class="bi bi-tools"></i> Nuevo Servicio</a>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h5 class="mb-0"><i class="bi bi-clock-history"></i> Servicios Recientes</h5></div>
  <div class="card-body p-0">
    <% if (serviciosRecientes.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th>Vehiculo</th>
            <th class="d-none d-md-table-cell">Cliente</th>
            <th class="d-none d-lg-table-cell">Descripcion</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% serviciosRecientes.forEach(s => { %>
          <tr>
            <td class="text-nowrap"><%= s.fecha ? s.fecha.substring(0, 10) : '' %></td>
            <td><%= s.placa %> <span class="text-muted"><%= s.marca %> <%= s.modelo %></span></td>
            <td class="d-none d-md-table-cell"><%= s.cliente_nombre %></td>
            <td class="d-none d-lg-table-cell"><%= s.descripcion ? s.descripcion.substring(0, 60) : '' %></td>
            <td>
              <span class="badge bg-<%= badgeEstado(s.estado) %>"><%= s.estado %></span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
        <p class="mb-1">Aun no hay servicios registrados.</p>
        <a href="/servicios/crear" class="btn btn-sm btn-primary mt-2">
          <i class="bi bi-plus-lg"></i> Crear el primero
        </a>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
