<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Gestion Taller</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body {
      background: #122a3d;
      background-image: linear-gradient(160deg, #1c3a52 0%, #0e2233 100%);
      min-height: 100vh; min-height: 100dvh;
      display: flex; align-items: center; justify-content: center;
      padding: 1.5rem;
    }
    .login-card { max-width: 400px; width: 100%; }
    .login-card .card { border: none; border-radius: 1rem; }
    .login-card .btn-primary { padding-top: .6rem; padding-bottom: .6rem; }
    .login-card .form-control:focus, .login-card .btn:focus {
      box-shadow: 0 0 0 .25rem rgba(31, 95, 139, .35);
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="card shadow-lg">
      <div class="card-body p-4 p-sm-5">
        <div class="text-center mb-4">
          <i class="bi bi-key text-primary" style="font-size: 3rem;"></i>
          <h3 class="mt-2 mb-1">Recuperar Contrasena</h3>
          <p class="text-muted mb-0">Te enviaremos un enlace para restablecerla</p>
        </div>
        <% if (mensaje) { %>
          <div class="alert alert-success"><%= mensaje %></div>
          <p class="text-center mt-3 mb-0">
            <a href="/auth/login"><i class="bi bi-arrow-left"></i> Volver a iniciar sesion</a>
          </p>
        <% } else { %>
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          <form method="POST" action="/auth/recuperar">
            <div class="mb-4">
              <label for="email" class="form-label">Correo electronico</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input type="email" id="email" name="email" class="form-control" autocomplete="email" required autofocus>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-send"></i> Enviar enlace</button>
          </form>
          <p class="text-center mt-3 mb-0">
            <a href="/auth/login"><i class="bi bi-arrow-left"></i> Volver a iniciar sesion</a>
          </p>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
