<%- include('../partials/header') %>

<h2><i class="bi bi-person-fill-gear"></i> <%= title %></h2>
<hr>

<% if (errors.length) { %>
<div class="alert alert-danger">
  <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<form method="POST" action="/usuarios<%= user.id ? `/${user.id}/editar` : '/crear' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="row g-3" style="max-width: 600px;">
    <div class="col-12">
      <label class="form-label" for="usr-nombre">Nombre Completo *</label>
      <input type="text" name="nombre" id="usr-nombre" class="form-control" value="<%= user.nombre || '' %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label" for="usr-usuario">Usuario *</label>
      <input type="text" name="usuario" id="usr-usuario" class="form-control" value="<%= user.usuario || '' %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label" for="usr-email">Correo electronico</label>
      <input type="email" name="email" id="usr-email" class="form-control" value="<%= user.email || '' %>">
    </div>
    <div class="col-md-6">
      <label class="form-label" for="usr-rol">Rol</label>
      <select name="rol" id="usr-rol" class="form-select">
        <option value="tecnico" <%= (user.rol || 'tecnico') === 'tecnico' ? 'selected' : '' %>>Tecnico</option>
        <option value="admin" <%= user.rol === 'admin' ? 'selected' : '' %>>Administrador</option>
      </select>
    </div>
    <div class="col-md-6">
      <label class="form-label" for="usr-password">Clave <%= user.id ? '(dejar vacio para no cambiar)' : '*' %></label>
      <input type="password" name="password" id="usr-password" class="form-control" <%= user.id ? '' : 'required' %> minlength="4">
    </div>
    <div class="col-md-6">
      <label class="form-label" for="usr-password2">Confirmar Clave</label>
      <input type="password" name="password2" id="usr-password2" class="form-control">
    </div>
    <% if (user.id) { %>
    <div class="col-12">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" name="activo" id="activo" <%= (user.activo === undefined || user.activo) ? 'checked' : '' %>>
        <label class="form-check-label" for="activo">Usuario activo</label>
      </div>
    </div>
    <% } %>
  </div>
  <div class="mt-4">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
    <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>

<%- include('../partials/footer') %>
