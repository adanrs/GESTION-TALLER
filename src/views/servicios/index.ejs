<%- include('../partials/header') %>

<%
  // Helper inline: estado -> clase de badge Bootstrap
  function badgeEstado(e) {
    switch (e) {
      case 'Pendiente':  return 'bg-secondary';
      case 'Asignada':   return 'bg-info text-dark';
      case 'En proceso': return 'bg-warning text-dark';
      case 'Completada': return 'bg-success';
      case 'Por cobrar': return 'bg-primary';
      case 'Cobrada':    return 'bg-dark';
      case 'Cancelada':  return 'bg-danger';
      default:           return 'bg-secondary';
    }
  }
  var estadosCanonicos = ['Pendiente','Asignada','En proceso','Completada','Por cobrar','Cobrada','Cancelada'];
%>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-tools"></i> <%= esMecanico ? 'Mis Ordenes' : 'Servicios' %>
  </h2>
  <% if (!esMecanico) { %>
  <a href="/servicios/crear" class="btn btn-primary">
    <i class="bi bi-plus-lg"></i> Nuevo Servicio
  </a>
  <% } %>
</div>

<form class="row g-2 mb-3" method="GET">
  <div class="col-12 col-md flex-md-grow-1">
    <input type="text" name="buscar" class="form-control"
           placeholder="Buscar por placa, cliente o descripcion..."
           value="<%= buscar %>">
  </div>
  <div class="col-8 col-md-auto">
    <select name="estado" class="form-select">
      <option value="">Todos los estados</option>
      <% estadosCanonicos.forEach(function(e) { %>
      <option value="<%= e %>" <%= estado === e ? 'selected' : '' %>><%= e %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-4 col-md-auto">
    <button class="btn btn-outline-secondary w-100"><i class="bi bi-search"></i> Filtrar</button>
  </div>
  <% if (buscar || estado) { %>
  <div class="col-12 col-md-auto">
    <a href="/servicios" class="btn btn-outline-danger w-100">Limpiar</a>
  </div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (servicios.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th>Vehiculo</th>
            <th class="d-none d-md-table-cell">Cliente</th>
            <th class="d-none d-lg-table-cell">Descripcion</th>
            <th class="d-none d-md-table-cell">Mecanico</th>
            <th class="d-none d-lg-table-cell">Tecnico</th>
            <th class="d-none d-md-table-cell text-end">Costo</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% servicios.forEach(function(s) { %>
          <tr>
            <td class="text-nowrap"><%= s.fecha ? s.fecha.substring(0, 10) : '' %></td>
            <td>
              <a href="/vehiculos/<%= s.vehiculo_id %>"><%= s.placa %></a>
              <span class="text-muted"><%= s.marca %> <%= s.modelo %></span>
            </td>
            <td class="d-none d-md-table-cell"><%= s.cliente_nombre %></td>
            <td class="d-none d-lg-table-cell">
              <%= s.descripcion ? s.descripcion.substring(0, 50) : '' %>
            </td>
            <td class="d-none d-md-table-cell">
              <% if (s.mecanico_nombre) { %>
                <%= s.mecanico_nombre %>
              <% } else { %>
                <span class="badge bg-light text-muted border">Sin asignar</span>
              <% } %>
            </td>
            <td class="d-none d-lg-table-cell"><%= s.tecnico || '-' %></td>
            <td class="d-none d-md-table-cell text-end text-nowrap">$<%= (s.costo || 0).toFixed(2) %></td>
            <td>
              <span class="badge <%= badgeEstado(s.estado) %>"><%= s.estado %></span>
              <% if (s.cobrado) { %>
                <span class="badge bg-dark"><i class="bi bi-cash-coin"></i></span>
              <% } %>
            </td>
            <td class="text-end text-nowrap">
              <a href="/servicios/<%= s.id %>" class="btn btn-sm btn-outline-secondary" title="Ver detalle">
                <i class="bi bi-eye"></i><span class="d-none d-sm-inline"> Ver</span>
              </a>
              <% if (!esMecanico) { %>
              <a href="/servicios/<%= s.id %>/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              <form method="POST" action="/servicios/<%= s.id %>/eliminar" class="d-inline"
                    onsubmit="return confirm('Eliminar este servicio?')">
                <button class="btn btn-sm btn-outline-danger" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        <% if (buscar || estado) { %>
          <p class="mb-0">No hay servicios que coincidan con el filtro.</p>
          <a href="/servicios" class="btn btn-sm btn-outline-secondary mt-2">Limpiar filtros</a>
        <% } else { %>
          <p class="mb-0">Aun no hay servicios registrados.</p>
          <% if (!esMecanico) { %>
          <a href="/servicios/crear" class="btn btn-sm btn-primary mt-2">
            <i class="bi bi-plus-lg"></i> Crear el primero
          </a>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
