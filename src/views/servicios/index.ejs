<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-tools"></i> Servicios</h2>
  <a href="/servicios/crear" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Servicio</a>
</div>

<form class="row g-2 mb-3" method="GET">
  <div class="col-auto flex-grow-1">
    <input type="text" name="buscar" class="form-control" placeholder="Buscar por placa, cliente o descripcion..." value="<%= buscar %>">
  </div>
  <div class="col-auto">
    <select name="estado" class="form-select">
      <option value="">Todos los estados</option>
      <% ['Pendiente','En Proceso','Completado','Cancelado'].forEach(e => { %>
      <option value="<%= e %>" <%= estado === e ? 'selected' : '' %>><%= e %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-secondary"><i class="bi bi-search"></i> Filtrar</button>
  </div>
  <% if (buscar || estado) { %>
  <div class="col-auto"><a href="/servicios" class="btn btn-outline-danger">Limpiar</a></div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (servicios.length) { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th>Vehiculo</th>
            <th>Cliente</th>
            <th>Descripcion</th>
            <th>Tecnico</th>
            <th>Costo</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% servicios.forEach(s => { %>
          <tr>
            <td><%= s.fecha ? s.fecha.substring(0, 10) : '' %></td>
            <td><a href="/vehiculos/<%= s.vehiculo_id %>"><%= s.placa %></a> <%= s.marca %> <%= s.modelo %></td>
            <td><%= s.cliente_nombre %></td>
            <td><%= s.descripcion.substring(0, 50) %></td>
            <td><%= s.tecnico || '-' %></td>
            <td>$<%= (s.costo || 0).toFixed(2) %></td>
            <td>
              <% if (s.estado === 'Completado') { %>
                <span class="badge bg-success"><%= s.estado %></span>
              <% } else if (s.estado === 'En Proceso') { %>
                <span class="badge bg-warning text-dark"><%= s.estado %></span>
              <% } else if (s.estado === 'Cancelado') { %>
                <span class="badge bg-danger"><%= s.estado %></span>
              <% } else { %>
                <span class="badge bg-secondary"><%= s.estado %></span>
              <% } %>
            </td>
            <td class="text-end">
              <a href="/servicios/<%= s.id %>/editar" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/servicios/<%= s.id %>/eliminar" class="d-inline" onsubmit="return confirm('Eliminar este servicio?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="text-muted p-3 mb-0">No se encontraron servicios.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
