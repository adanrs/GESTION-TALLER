<%- include('../partials/header') %>

<%
  var faltanTareas = (totalTareas > 0 && tareasCompletadas < totalTareas);
%>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-tools"></i> Servicio #<%= servicio.id %>
    <span class="badge bg-<%= badgeEstado(servicio.estado) %> align-middle"><%= servicio.estado %></span>
    <% if (servicio.cobrado) { %>
      <span class="badge bg-dark align-middle"><i class="bi bi-cash-coin"></i> COBRADA</span>
    <% } %>
  </h2>
  <div class="d-flex flex-wrap gap-2">
    <% if (esAdmin) { %>
    <a href="/servicios/<%= servicio.id %>/editar" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
    <% } %>
    <a href="/servicios/<%= servicio.id %>/pdf" target="_blank" class="btn btn-outline-dark"><i class="bi bi-printer"></i> Imprimir / PDF</a>
    <a href="/vehiculos/<%= servicio.vehiculo_id %>" class="btn btn-outline-secondary"><i class="bi bi-car-front"></i> Ver Vehiculo</a>
    <a href="/servicios" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="row g-2">
      <div class="col-12 col-md-4"><strong>Vehiculo:</strong> <a href="/vehiculos/<%= servicio.vehiculo_id %>"><%= servicio.placa %> - <%= servicio.marca %> <%= servicio.modelo %></a></div>
      <div class="col-6 col-md-4"><strong>Cliente:</strong> <%= servicio.cliente_nombre %></div>
      <div class="col-6 col-md-4"><strong>Mecanico asignado:</strong>
        <% if (servicio.mecanico_nombre) { %>
          <%= servicio.mecanico_nombre %>
        <% } else { %>
          <span class="badge bg-light text-muted border">Sin asignar</span>
        <% } %>
      </div>
    </div>
    <div class="row g-2 mt-1">
      <div class="col-12 col-md-6"><strong>Descripcion:</strong> <%= servicio.descripcion %></div>
      <div class="col-4 col-md-2"><strong>Km:</strong> <%= servicio.kilometraje || '-' %></div>
      <div class="col-4 col-md-2"><strong>Tecnico:</strong> <%= servicio.tecnico || '-' %></div>
      <% if (esAdmin) { %>
      <div class="col-4 col-md-2"><strong>Mano de obra:</strong> $<%= (servicio.costo || 0).toFixed(2) %></div>
      <% } %>
    </div>
    <div class="row g-2 mt-1">
      <div class="col-6 col-md-4"><strong>Fecha:</strong> <%= servicio.fecha ? servicio.fecha.substring(0, 10) : '' %></div>
      <% if (servicio.fecha_completado) { %>
      <div class="col-6 col-md-4"><strong>Completada:</strong> <span class="text-success"><%= servicio.fecha_completado %></span></div>
      <% } %>
      <% if (servicio.cobrado && servicio.fecha_cobro) { %>
      <div class="col-6 col-md-4"><strong>Cobrada:</strong> <span class="text-dark"><%= servicio.fecha_cobro %></span></div>
      <% } %>
    </div>
    <% if (servicio.notas) { %>
    <div class="mt-2"><strong>Notas:</strong> <%= servicio.notas %></div>
    <% } %>
  </div>
</div>

<!-- Acciones de estado -->
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
      <% if ((esAdmin || esMecanico) && (servicio.estado === 'Pendiente' || servicio.estado === 'Asignada')) { %>
      <form method="POST" action="/servicios/<%= servicio.id %>/iniciar" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary"><i class="bi bi-play-fill"></i> Voy a trabajarla</button>
      </form>
      <% } %>
      <form method="POST" action="/servicios/<%= servicio.id %>/completar" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-success <%= faltanTareas ? 'opacity-75' : '' %>"
                <% if (faltanTareas) { %>title="Faltan tareas por completar (<%= tareasCompletadas %>/<%= totalTareas %>)"<% } %>>
          <i class="bi bi-check2-circle"></i> Completar orden
        </button>
      </form>
      <% if (esAdmin) { %>
      <form method="POST" action="/servicios/<%= servicio.id %>/por-cobrar" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary"><i class="bi bi-receipt"></i> Marcar por cobrar</button>
      </form>
      <form method="POST" action="/servicios/<%= servicio.id %>/cobrar" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-dark"><i class="bi bi-cash-coin"></i> Marcar cobrada</button>
      </form>
      <a href="/servicios/<%= servicio.id %>/editar" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
      <form method="POST" action="/servicios/<%= servicio.id %>/eliminar" class="d-inline"
            onsubmit="return confirm('Eliminar este servicio?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Eliminar</button>
      </form>
      <% } %>
    </div>
    <% if (faltanTareas) { %>
    <p class="small text-muted mb-0 mt-2">
      <i class="bi bi-info-circle"></i> Quedan tareas pendientes (<%= tareasCompletadas %> de <%= totalTareas %> completadas).
    </p>
    <% } %>
  </div>
</div>

<!-- Hoja de servicio - Tareas -->
<div class="card mb-4">
  <div class="card-header d-flex align-items-center gap-2">
    <h5 class="mb-0"><i class="bi bi-list-check"></i> Hoja de servicio - Tareas</h5>
    <% if (totalTareas > 0) { %>
    <span class="badge bg-<%= tareasCompletadas === totalTareas ? 'success' : 'secondary' %> ms-auto">
      <%= tareasCompletadas %> / <%= totalTareas %> completadas
    </span>
    <% } %>
  </div>
  <div class="card-body">
    <% if (totalTareas > 0) { %>
    <div class="progress mb-3" style="height: 18px;">
      <div class="progress-bar bg-success" role="progressbar"
           style="width: <%= Math.round((tareasCompletadas / totalTareas) * 100) %>%"
           aria-valuenow="<%= tareasCompletadas %>"
           aria-valuemin="0" aria-valuemax="<%= totalTareas %>">
        <%= tareasCompletadas %> de <%= totalTareas %> completadas
      </div>
    </div>
    <ul class="list-group list-group-flush">
      <% tareas.forEach(function(tarea) { %>
      <li class="list-group-item d-flex align-items-center gap-3 px-0">
        <% if (tarea.completado) { %>
          <i class="bi bi-check-circle-fill text-success fs-5 flex-shrink-0"></i>
        <% } else { %>
          <i class="bi bi-circle text-secondary fs-5 flex-shrink-0"></i>
        <% } %>
        <div class="flex-grow-1">
          <span class="<%= tarea.completado ? 'text-decoration-line-through text-muted' : '' %>"><%= tarea.descripcion %></span>
          <% if (tarea.completado && (tarea.tecnico || tarea.fecha_completado)) { %>
          <div class="small text-muted">
            por <strong><%= tarea.tecnico || 'N/A' %></strong>
            <% if (tarea.fecha_completado) { %>&mdash; <%= tarea.fecha_completado %><% } %>
          </div>
          <% } %>
        </div>
        <form method="POST" action="/servicios/<%= servicio.id %>/tareas/<%= tarea.id %>/toggle" class="flex-shrink-0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% if (tarea.completado) { %>
          <button type="submit" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-counterclockwise"></i> Reabrir
          </button>
          <% } else { %>
          <button type="submit" class="btn btn-sm btn-outline-success">
            <i class="bi bi-check-lg"></i> Marcar hecha
          </button>
          <% } %>
        </form>
      </li>
      <% }) %>
    </ul>
    <% } else { %>
    <p class="text-muted mb-0"><i class="bi bi-info-circle"></i> Sin tareas registradas para este servicio.</p>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-header"><h5 class="mb-0"><i class="bi bi-box-seam"></i> Repuestos / Materiales</h5></div>
  <div class="card-body">
    <% if (esAdmin || esMecanico) { %>
    <form method="POST" action="/servicios/<%= servicio.id %>/items" class="row g-2 align-items-end mb-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="col-12 col-sm-6 col-md-3">
        <label class="form-label" for="item-tipo">Tipo</label>
        <select name="tipo" id="item-tipo" class="form-select">
          <option value="Repuesto" selected>Repuesto</option>
          <option value="Mano de obra">Mano de obra</option>
          <option value="Material">Material</option>
        </select>
      </div>
      <div class="col-12 <%= esAdmin ? 'col-md-4' : 'col-md-6' %>">
        <label class="form-label" for="item-desc">Descripcion</label>
        <input type="text" id="item-desc" name="descripcion" class="form-control" placeholder="Que se ocupa..." required>
      </div>
      <div class="col-6 col-sm-3 col-md-2">
        <label class="form-label" for="item-cant">Cantidad</label>
        <input type="number" id="item-cant" name="cantidad" class="form-control" value="1" min="0" step="any">
      </div>
      <% if (esAdmin) { %>
      <div class="col-6 col-sm-3 col-md-2">
        <label class="form-label" for="item-precio">Precio Unit.</label>
        <input type="number" id="item-precio" name="precio_unitario" class="form-control" value="0" min="0" step="any">
      </div>
      <% } %>
      <div class="col-12 col-sm-6 col-md-1 d-grid">
        <button type="submit" class="btn btn-success"><i class="bi bi-plus-lg"></i> Agregar</button>
      </div>
    </form>
    <% } %>

    <% if (items.length) { %>
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Tipo</th>
            <th>Descripcion</th>
            <th class="text-center">Cantidad</th>
            <% if (esAdmin) { %>
            <th class="text-end">Precio Unit.</th>
            <th class="text-end">Subtotal</th>
            <% } %>
            <% if (esAdmin || esMecanico) { %>
            <th class="text-end">Accion</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((it, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><span class="badge bg-<%= it.tipo === 'Servicio' || it.tipo === 'Mano de obra' ? 'info' : 'warning' %>"><%= it.tipo %></span></td>
            <td><%= it.descripcion %></td>
            <td class="text-center"><%= it.cantidad %></td>
            <% if (esAdmin) { %>
            <td class="text-end">$<%= it.precio_unitario.toFixed(2) %></td>
            <td class="text-end">$<%= (it.cantidad * it.precio_unitario).toFixed(2) %></td>
            <% } %>
            <% if (esAdmin || esMecanico) { %>
            <td class="text-end">
              <form method="POST" action="/servicios/<%= servicio.id %>/items/<%= it.id %>/eliminar" class="d-inline"
                    onsubmit="return confirm('Eliminar este item?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
        <% if (esAdmin) { %>
        <tfoot>
          <tr>
            <td colspan="5" class="text-end"><strong>Total repuestos:</strong></td>
            <td class="text-end fw-bold">$<%= totalItems.toFixed(2) %></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="5" class="text-end"><strong>Mano de obra:</strong></td>
            <td class="text-end fw-bold">$<%= (servicio.costo || 0).toFixed(2) %></td>
            <td></td>
          </tr>
          <tr class="table-dark">
            <td colspan="5" class="text-end"><strong>TOTAL SERVICIO:</strong></td>
            <td class="text-end fw-bold fs-5">$<%= (totalItems + (servicio.costo || 0)).toFixed(2) %></td>
            <td></td>
          </tr>
        </tfoot>
        <% } %>
      </table>
    </div>
    <% } else { %>
    <p class="text-muted mb-0"><i class="bi bi-info-circle"></i> Sin repuestos ni materiales registrados aun.</p>
    <% } %>
  </div>
</div>

<!-- Comentarios -->
<div class="card mt-4">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-chat-left-text"></i> Comentarios</h5>
  </div>
  <div class="card-body">
    <form method="POST" action="/servicios/<%= servicio.id %>/comentario" class="mb-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="form-label" for="comentario">Agregar comentario</label>
      <textarea name="comentario" id="comentario" class="form-control mb-2" rows="2"
                placeholder="Escribe una nota o actualizacion sobre esta orden..." required></textarea>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-send"></i> Agregar comentario
      </button>
    </form>

    <% if (comentarios && comentarios.length) { %>
    <ul class="list-group list-group-flush">
      <% comentarios.forEach(function(c) { %>
      <li class="list-group-item px-0">
        <div class="d-flex flex-wrap justify-content-between align-items-baseline gap-2">
          <strong><i class="bi bi-person-circle"></i> <%= c.autor %></strong>
          <span class="small text-muted"><%= c.fecha %></span>
        </div>
        <div class="mt-1" style="white-space: pre-wrap;"><%= c.comentario %></div>
      </li>
      <% }) %>
    </ul>
    <% } else { %>
    <p class="text-muted mb-0"><i class="bi bi-info-circle"></i> Sin comentarios.</p>
    <% } %>
  </div>
</div>

<!-- Fotos -->
<div class="card mt-4">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-images"></i> Fotos</h5>
  </div>
  <div class="card-body">
    <% if (esAdmin || esMecanico) { %>
    <form method="POST" action="/fotos/subir?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="row g-2 align-items-end mb-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="servicio_id" value="<%= servicio.id %>">
      <div class="col-12 col-md-5">
        <label class="form-label" for="fotos-srv">Seleccionar fotos</label>
        <input type="file" id="fotos-srv" name="fotos" multiple accept="image/*" class="form-control" required>
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label" for="desc-srv">Descripcion</label>
        <input type="text" id="desc-srv" name="descripcion" class="form-control" placeholder="Descripcion (opcional)">
      </div>
      <div class="col-12 col-md-3 d-grid">
        <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Subir fotos</button>
      </div>
      <div class="col-12">
        <small class="text-muted">JPG, PNG o WEBP, hasta 5MB cada una.</small>
      </div>
    </form>
    <% } %>

    <% if (fotos && fotos.length) { %>
    <div class="row g-2">
      <% fotos.forEach(function(f) { %>
      <div class="col-6 col-sm-4 col-md-3 col-lg-2">
        <div class="position-relative">
          <img src="/fotos/<%= f.id %>/ver"
               class="img-fluid rounded foto-thumb border"
               style="aspect-ratio:1/1; object-fit:cover; width:100%; cursor:pointer"
               loading="lazy"
               alt="<%= f.descripcion || f.nombre_original || 'Foto' %>"
               data-src="/fotos/<%= f.id %>/ver"
               data-desc="<%= f.descripcion || f.nombre_original || '' %>">
          <% if (f.descripcion) { %>
          <div class="small text-muted text-truncate mt-1" title="<%= f.descripcion %>"><%= f.descripcion %></div>
          <% } %>
          <% if (esAdmin || esMecanico) { %>
          <form method="POST" action="/fotos/<%= f.id %>/eliminar" class="mt-1"
                onsubmit="return confirm('Eliminar esta foto?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-trash"></i> Eliminar</button>
          </form>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
      <p class="text-muted mb-0">Sin fotos. Agrega la primera.</p>
    <% } %>
  </div>
</div>

<!-- Modal lightbox de fotos -->
<div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true" aria-labelledby="fotoModalLabel">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-fullscreen-sm-down">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="fotoModalLabel">Foto</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body text-center">
        <img id="fotoModalImg" src="" class="img-fluid rounded" alt="Foto ampliada">
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var modalEl = document.getElementById('fotoModal');
  if (!modalEl || typeof bootstrap === 'undefined') return;
  var modal = new bootstrap.Modal(modalEl);
  var modalImg = document.getElementById('fotoModalImg');
  var modalLabel = document.getElementById('fotoModalLabel');
  document.querySelectorAll('.foto-thumb').forEach(function (img) {
    img.addEventListener('click', function () {
      modalImg.src = img.getAttribute('data-src');
      var desc = img.getAttribute('data-desc') || 'Foto';
      modalImg.alt = desc;
      modalLabel.textContent = desc;
      modal.show();
    });
  });
})();
</script>

<%- include('../partials/footer') %>
