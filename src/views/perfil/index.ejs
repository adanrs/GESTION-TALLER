<%- include('../partials/header') %>

<h2><i class="bi bi-person-gear"></i> Mi Perfil</h2>
<hr>

<% if (errors.length) { %>
<div class="alert alert-danger">
  <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<div style="max-width: 600px;">
  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title mb-3"><i class="bi bi-person-vcard"></i> Datos de la cuenta</h5>
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label text-muted mb-1">Nombre</label>
          <div><%= user.nombre %></div>
        </div>
        <div class="col-md-6">
          <label class="form-label text-muted mb-1">Usuario</label>
          <div><code><%= user.usuario %></code></div>
        </div>
        <div class="col-md-6">
          <label class="form-label text-muted mb-1">Rol</label>
          <div><span class="badge bg-secondary"><%= user.rol %></span></div>
        </div>
      </div>
      <hr>
      <form method="POST" action="/perfil/email">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-3">
          <label class="form-label" for="perfil-email">Correo electronico (para recuperar contrasena)</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" id="perfil-email" class="form-control" value="<%= user.email || '' %>">
          </div>
        </div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar correo</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5 class="card-title mb-3"><i class="bi bi-shield-lock"></i> Cambiar contrasena</h5>
      <form method="POST" action="/perfil/password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label" for="perfil-actual">Contrasena actual *</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="actual" id="perfil-actual" class="form-control" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label" for="perfil-password">Nueva contrasena *</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password" id="perfil-password" class="form-control" minlength="4" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label" for="perfil-password2">Confirmar nueva contrasena *</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password2" id="perfil-password2" class="form-control" required>
            </div>
          </div>
        </div>
        <div class="mt-4">
          <button type="submit" class="btn btn-primary"><i class="bi bi-key"></i> Cambiar contrasena</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
