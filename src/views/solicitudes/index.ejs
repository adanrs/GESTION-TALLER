<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0"><i class="bi bi-inbox"></i> Solicitudes</h2>
</div>

<form class="row g-2 mb-3" method="GET">
  <div class="col-12 col-md-auto flex-md-grow-1">
    <label class="form-label small text-muted mb-1" for="estado">Filtrar por estado</label>
    <select class="form-select" id="estado" name="estado" onchange="this.form.submit()">
      <% var estados = ['Todos', 'Solicitada', 'Aprobada', 'Rechazada', 'Convertida']; %>
      <% estados.forEach(function(e) { %>
      <% var val = (e === 'Todos') ? '' : e; %>
      <option value="<%= val %>" <%= (estado || '') === val ? 'selected' : '' %>><%= e %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-12 col-md-auto d-flex align-items-end">
    <button class="btn btn-outline-secondary w-100"><i class="bi bi-funnel"></i> Filtrar</button>
  </div>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (solicitudes && solicitudes.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha</th>
            <th>Cliente</th>
            <th class="d-none d-md-table-cell">Vehiculo</th>
            <th class="d-none d-lg-table-cell">Descripcion</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% solicitudes.forEach(function(s) { %>
          <tr>
            <td class="text-nowrap"><%= s.fecha ? s.fecha.substring(0, 10) : '-' %></td>
            <td>
              <%= s.cliente_nombre %>
              <div class="d-md-none small text-muted"><%= s.placa %></div>
            </td>
            <td class="d-none d-md-table-cell">
              <%= s.placa %>
              <div class="small text-muted"><%= s.marca %> <%= s.modelo %></div>
            </td>
            <td class="d-none d-lg-table-cell">
              <span title="<%= s.descripcion %>"><%= s.descripcion.length > 60 ? s.descripcion.substring(0, 60) + '...' : s.descripcion %></span>
            </td>
            <td><span class="badge bg-<%= badgeEstado(s.estado) %>"><%= s.estado %></span></td>
            <td class="text-end text-nowrap">
              <a href="/solicitudes/<%= s.id %>" class="btn btn-sm btn-outline-secondary" title="Ver detalle">
                <i class="bi bi-eye"></i> Ver
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        <% if (estado) { %>
          <p class="mb-0">No hay solicitudes con el estado "<%= estado %>".</p>
          <a href="/solicitudes" class="btn btn-sm btn-outline-secondary mt-2">Ver todas</a>
        <% } else { %>
          <p class="mb-0">Aun no hay solicitudes de clientes.</p>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
