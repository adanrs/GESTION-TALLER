<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-inbox"></i> Solicitud
    <span class="badge bg-<%= badgeEstado(solicitud.estado) %> align-middle"><%= solicitud.estado %></span>
  </h2>
  <a href="/solicitudes" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card mb-4">
  <div class="card-header"><h6 class="mb-0 text-uppercase text-muted"><i class="bi bi-info-circle"></i> Datos de la solicitud</h6></div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="small text-muted text-uppercase">Cliente</div>
        <div class="fw-semibold"><%= solicitud.cliente_nombre %></div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="small text-muted text-uppercase">Vehiculo</div>
        <div class="fw-semibold"><%= solicitud.placa %> - <%= solicitud.marca %> <%= solicitud.modelo %></div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="small text-muted text-uppercase">Fecha</div>
        <div class="fw-semibold"><%= solicitud.fecha ? solicitud.fecha.substring(0, 10) : '-' %></div>
      </div>
      <% if (solicitud.fecha_resuelta) { %>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="small text-muted text-uppercase">Fecha resuelta</div>
        <div class="fw-semibold"><%= solicitud.fecha_resuelta.substring(0, 10) %></div>
      </div>
      <% } %>
      <div class="col-12">
        <div class="small text-muted text-uppercase">Descripcion</div>
        <div class="fw-semibold" style="white-space: pre-wrap;"><%= solicitud.descripcion %></div>
      </div>
      <% if (solicitud.estado === 'Rechazada' && solicitud.nota_taller) { %>
      <div class="col-12">
        <div class="alert alert-warning mb-0">
          <div class="small text-uppercase fw-semibold"><i class="bi bi-exclamation-triangle"></i> Motivo de rechazo</div>
          <div style="white-space: pre-wrap;"><%= solicitud.nota_taller %></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Acciones -->
<div class="card">
  <div class="card-header"><h6 class="mb-0 text-uppercase text-muted"><i class="bi bi-gear"></i> Acciones</h6></div>
  <div class="card-body">
    <% if (solicitud.servicio_id) { %>
    <div class="d-flex flex-wrap align-items-center gap-2">
      <span class="text-success"><i class="bi bi-check-circle"></i> Esta solicitud ya fue convertida en orden de servicio.</span>
      <a href="/servicios/<%= solicitud.servicio_id %>" class="btn btn-outline-primary">
        <i class="bi bi-tools"></i> Ver orden
      </a>
    </div>
    <% } else { %>
    <div class="d-flex flex-wrap gap-2">
      <% if (solicitud.estado === 'Solicitada') { %>
      <form method="POST" action="/solicitudes/<%= solicitud.id %>/aprobar" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Aprobar</button>
      </form>
      <% } %>

      <% if (solicitud.estado === 'Solicitada' || solicitud.estado === 'Aprobada') { %>
      <button type="button" class="btn btn-outline-danger" data-bs-toggle="collapse" data-bs-target="#rechazarForm">
        <i class="bi bi-x-lg"></i> Rechazar
      </button>
      <form method="POST" action="/solicitudes/<%= solicitud.id %>/convertir" class="d-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-right-circle"></i> Convertir a orden</button>
      </form>
      <% } %>
    </div>

    <% if (solicitud.estado === 'Solicitada' || solicitud.estado === 'Aprobada') { %>
    <div class="collapse mt-3" id="rechazarForm">
      <form method="POST" action="/solicitudes/<%= solicitud.id %>/rechazar">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-2">
          <label class="form-label" for="nota_taller">Motivo del rechazo</label>
          <textarea class="form-control" id="nota_taller" name="nota_taller" rows="3" required
                    placeholder="Explica al cliente por que se rechaza la solicitud..."></textarea>
        </div>
        <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg"></i> Confirmar rechazo</button>
      </form>
    </div>
    <% } %>

    <% if (solicitud.estado === 'Rechazada') { %>
    <p class="text-muted mb-0"><i class="bi bi-info-circle"></i> Esta solicitud fue rechazada. No hay acciones disponibles.</p>
    <% } %>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
