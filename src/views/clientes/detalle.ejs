<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-person"></i> <%= cliente.nombre %></h2>
  <div>
    <a href="/clientes/<%= cliente.id %>/editar" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
    <a href="/clientes" class="btn btn-outline-secondary">Volver</a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="row">
      <div class="col-md-3"><strong>Cedula/RIF:</strong> <%= cliente.cedula || '-' %></div>
      <div class="col-md-3"><strong>Telefono:</strong> <%= cliente.telefono || '-' %></div>
      <div class="col-md-3"><strong>Email:</strong> <%= cliente.email || '-' %></div>
      <div class="col-md-3"><strong>Registro:</strong> <%= cliente.fecha_registro ? cliente.fecha_registro.substring(0, 10) : '' %></div>
    </div>
    <% if (cliente.direccion) { %>
    <div class="mt-2"><strong>Direccion:</strong> <%= cliente.direccion %></div>
    <% } %>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-car-front"></i> Vehiculos (<%= vehiculos.length %>)</h4>
  <a href="/vehiculos/crear?cliente_id=<%= cliente.id %>" class="btn btn-sm btn-success"><i class="bi bi-plus-lg"></i> Agregar Vehiculo</a>
</div>

<% if (vehiculos.length) { %>
<div class="row g-3">
  <% vehiculos.forEach(v => { %>
  <div class="col-md-6 col-lg-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title"><a href="/vehiculos/<%= v.id %>"><%= v.placa %></a></h5>
        <p class="card-text mb-1"><%= v.marca %> <%= v.modelo %> <% if(v.ano) { %>(<%= v.ano %>)<% } %></p>
        <% if(v.color) { %><small class="text-muted">Color: <%= v.color %></small><% } %>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<p class="text-muted">Este cliente no tiene vehiculos registrados.</p>
<% } %>

<%- include('../partials/footer') %>
