<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-people"></i> Clientes
    <% if (archivados) { %><span class="badge bg-secondary align-middle">Archivados</span><% } %>
  </h2>
  <div class="d-flex flex-wrap gap-2">
    <% if (archivados) { %>
      <a href="/clientes" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Ver activos</a>
    <% } else { %>
      <a href="/clientes?archivados=1" class="btn btn-outline-secondary"><i class="bi bi-archive"></i> Ver archivados</a>
      <a href="/clientes/crear" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Cliente</a>
    <% } %>
  </div>
</div>

<form class="row g-2 mb-3" method="GET">
  <% if (archivados) { %><input type="hidden" name="archivados" value="1"><% } %>
  <div class="col-12 col-md flex-md-grow-1">
    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre, cedula o telefono..." value="<%= buscar %>">
  </div>
  <div class="col-6 col-md-auto">
    <button class="btn btn-outline-secondary w-100"><i class="bi bi-search"></i> Buscar</button>
  </div>
  <% if (buscar) { %>
  <div class="col-6 col-md-auto">
    <a href="<%= archivados ? '/clientes?archivados=1' : '/clientes' %>" class="btn btn-outline-danger w-100">Limpiar</a>
  </div>
  <% } %>
</form>

<div class="card">
  <div class="card-body p-0">
    <% if (clientes.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre</th>
            <th class="d-none d-md-table-cell">Cedula/RIF</th>
            <th class="d-none d-sm-table-cell">Telefono</th>
            <th class="d-none d-lg-table-cell">Email</th>
            <th class="text-center">Vehiculos</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% clientes.forEach(c => { %>
          <tr>
            <td>
              <a href="/clientes/<%= c.id %>" class="fw-semibold"><%= c.nombre %></a>
              <div class="d-md-none small text-muted"><%= c.cedula || '' %></div>
            </td>
            <td class="d-none d-md-table-cell"><%= c.cedula || '-' %></td>
            <td class="d-none d-sm-table-cell"><%= c.telefono || '-' %></td>
            <td class="d-none d-lg-table-cell"><%= c.email || '-' %></td>
            <td class="text-center"><span class="badge bg-secondary"><%= c.total_vehiculos %></span></td>
            <td class="text-end text-nowrap">
              <a href="/clientes/<%= c.id %>" class="btn btn-sm btn-outline-secondary" title="Ver detalle">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/clientes/<%= c.id %>/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              <% if (archivados) { %>
              <form method="POST" action="/clientes/<%= c.id %>/restaurar" class="d-inline" onsubmit="return confirm('Restaurar este registro?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-success" title="Restaurar"><i class="bi bi-arrow-counterclockwise"></i></button>
              </form>
              <% } else { %>
              <form method="POST" action="/clientes/<%= c.id %>/eliminar" class="d-inline" onsubmit="return confirm('Archivar este registro?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline-danger" title="Archivar"><i class="bi bi-archive"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-people fs-1 d-block mb-2"></i>
        <% if (buscar) { %>
          <p class="mb-0">No hay clientes que coincidan con la busqueda.</p>
          <a href="<%= archivados ? '/clientes?archivados=1' : '/clientes' %>" class="btn btn-sm btn-outline-secondary mt-2">Limpiar busqueda</a>
        <% } else if (archivados) { %>
          <p class="mb-0">No hay clientes archivados.</p>
          <a href="/clientes" class="btn btn-sm btn-outline-secondary mt-2"><i class="bi bi-arrow-left"></i> Ver activos</a>
        <% } else { %>
          <p class="mb-0">Aun no hay clientes registrados.</p>
          <a href="/clientes/crear" class="btn btn-sm btn-primary mt-2">
            <i class="bi bi-plus-lg"></i> Crear el primero
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
