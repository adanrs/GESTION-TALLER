<%- include('../partials/header') %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <h2 class="mb-0">
    <i class="bi bi-clock-history"></i> Linea de tiempo
    <span class="text-muted fs-5 d-block d-sm-inline"><%= cliente.nombre %></span>
  </h2>
  <div class="d-flex flex-wrap gap-2">
    <a href="/reportes/cliente/<%= cliente.id %>" class="btn btn-outline-dark" target="_blank">
      <i class="bi bi-file-earmark-pdf"></i> Reporte PDF
    </a>
    <a href="/clientes/<%= cliente.id %>" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Volver
    </a>
  </div>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-lg-3">
    <div class="card stat-card stat-card--success h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="stat-card__icon"><i class="bi bi-car-front"></i></span>
        <div>
          <div class="stat-card__value"><%= kpis.total_vehiculos || 0 %></div>
          <div class="stat-card__label">Vehiculos</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <div class="card stat-card stat-card--primary h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="stat-card__icon"><i class="bi bi-tools"></i></span>
        <div>
          <div class="stat-card__value"><%= kpis.total_ordenes || 0 %></div>
          <div class="stat-card__label">Total de ordenes</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <div class="card stat-card stat-card--info h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="stat-card__icon"><i class="bi bi-calendar-check"></i></span>
        <div>
          <div class="stat-card__value"><%= kpis.ultima_visita ? kpis.ultima_visita.substring(0, 10) : '-' %></div>
          <div class="stat-card__label">Ultima visita</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-lg-3">
    <div class="card stat-card stat-card--warning h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="stat-card__icon"><i class="bi bi-cash-coin"></i></span>
        <div>
          <div class="stat-card__value">$<%= (kpis.total_gastado || 0).toFixed(2) %></div>
          <div class="stat-card__label">Total gastado</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Vehiculos del cliente -->
<div class="card mb-4">
  <div class="card-header"><h6 class="mb-0 text-uppercase text-muted"><i class="bi bi-car-front"></i> Vehiculos</h6></div>
  <div class="card-body">
    <% if (vehiculos && vehiculos.length) { %>
    <div class="d-flex flex-wrap gap-2">
      <% vehiculos.forEach(function(v) { %>
      <a href="/vehiculos/<%= v.id %>/historial" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-car-front-fill"></i> <%= v.placa %>
        <span class="text-muted"><%= v.marca %> <%= v.modelo %></span>
      </a>
      <% }) %>
    </div>
    <% } else { %>
      <p class="text-muted mb-0">Este cliente no tiene vehiculos registrados.</p>
    <% } %>
  </div>
</div>

<!-- Timeline agregado -->
<div class="card">
  <div class="card-header"><h5 class="mb-0"><i class="bi bi-list-ul"></i> Eventos</h5></div>
  <div class="card-body">
    <% if (eventos && eventos.length) { %>
    <div class="list-group list-group-flush">
      <% eventos.forEach(function(ev) { %>
      <div class="list-group-item px-0">
        <div class="d-flex gap-3">
          <div class="flex-shrink-0">
            <span class="badge rounded-pill <%= ev.tipo === 'orden' ? 'bg-primary' : 'bg-info text-dark' %> fs-6">
              <i class="bi <%= ev.tipo === 'orden' ? 'bi-tools' : 'bi-receipt' %>"></i>
            </span>
          </div>
          <div class="flex-grow-1">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-1">
              <div class="d-flex flex-wrap align-items-center gap-2">
                <strong><%= ev.tipo === 'orden' ? 'Orden' : 'Cotizacion' %></strong>
                <% if (ev.placa) { %><span class="badge bg-light text-dark border"><i class="bi bi-car-front"></i> <%= ev.placa %></span><% } %>
                <% if (ev.numero) { %><code><%= ev.numero %></code><% } %>
                <% if (ev.estado) { %>
                <span class="badge bg-<%= badgeEstado(ev.estado) %>"><%= ev.estado %></span>
                <% } %>
              </div>
              <small class="text-muted text-nowrap">
                <i class="bi bi-calendar3"></i> <%= ev.fecha ? ev.fecha.substring(0, 10) : '-' %>
              </small>
            </div>
            <% if (ev.resumen) { %>
            <div class="text-body mb-1"><%= ev.resumen %></div>
            <% } %>
            <div class="d-flex flex-wrap gap-3 small text-muted">
              <% if (ev.tipo === 'orden' && ev.mecanico_nombre) { %>
              <span><i class="bi bi-person-gear"></i> <%= ev.mecanico_nombre %></span>
              <% } %>
              <% if (ev.total != null) { %>
              <span class="fw-semibold text-body"><i class="bi bi-cash"></i> $<%= (ev.total || 0).toFixed(2) %></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
      <div class="text-center text-muted p-5">
        <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
        <p class="mb-0">Este cliente aun no tiene ordenes ni cotizaciones registradas.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
